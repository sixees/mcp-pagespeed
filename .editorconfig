root = true

[*]
indent_style = space
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# Fork-specific code (configs/, scripts/, top-level configs we maintain).
[{configs,scripts}/**.ts]
indent_size = 2

[*.{json,md,yaml,yml}]
indent_size = 2

# Vendored upstream library — preserve upstream's 4-space style to keep
# diffs against upstream/main minimal.
[src/lib/**.ts]
indent_size = 4

[*.md]
trim_trailing_whitespace = false
