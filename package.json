{
  "name": "mcp-pagespeed",
  "version": "3.1.1",
  "private": true,
  "description": "MCP server exposing Google PageSpeed Insights (Lighthouse) analysis to LLM clients",
  "main": "dist/lib.js",
  "types": "dist/lib.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    },
    "./cli": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/lib/schema/index.d.ts",
      "import": "./dist/lib/schema/index.js"
    }
  },
  "bin": {
    "pagespeed-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "docs/README.md",
    "docs/api-schema.md",
    "docs/configuration.md",
    "docs/getting-started.md",
    "docs/internal"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sixees/mcp-pagespeed.git"
  },
  "homepage": "https://github.com/sixees/mcp-pagespeed#readme",
  "bugs": {
    "url": "https://github.com/sixees/mcp-pagespeed/issues"
  },
  "scripts": {
    "build": "tsup && node -e \"require('fs').chmodSync('dist/index.js', 0o755)\"",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "tsx scripts/smoke.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc -p tsconfig.fork.json"
  },
  "keywords": [
    "mcp",
    "pagespeed",
    "lighthouse",
    "core-web-vitals",
    "google-pagespeed-insights",
    "performance",
    "model-context-protocol",
    "claude"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^4.21.0",
    "js-yaml": "^4.1.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.20.0",
    "typescript": "^5.5.4",
    "vitest": "^4.0.18"
  }
}
