{
  "name": "mcp-curl",
  "version": "3.0.1",
  "description": "MCP server for executing cURL commands",
  "main": "dist/lib.js",
  "types": "dist/lib.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    },
    "./cli": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./lib": {
      "types": "./dist/lib/index.d.ts",
      "import": "./dist/lib/index.js"
    },
    "./schema": {
      "types": "./dist/lib/schema/index.d.ts",
      "import": "./dist/lib/schema/index.js"
    }
  },
  "bin": {
    "curl-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "docs"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sixees/mcp-curl.git"
  },
  "homepage": "https://github.com/sixees/mcp-curl#readme",
  "bugs": {
    "url": "https://github.com/sixees/mcp-curl/issues"
  },
  "scripts": {
    "build": "tsup && node -e \"require('fs').chmodSync('dist/index.js', 0o755)\"",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "curl",
    "http",
    "model-context-protocol",
    "claude"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^4.21.0",
    "js-yaml": "^4.1.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.5.4",
    "vitest": "^4.0.18"
  }
}
