{
  "name": "curl-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for executing cURL commands",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "curl-mcp-server": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
