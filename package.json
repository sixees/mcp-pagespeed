{
  "name": "mcp-curl",
  "version": "1.0.2",
  "description": "MCP server for executing cURL commands",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "curl-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sixees/mcp-curl.git"
  },
  "homepage": "https://github.com/sixees/mcp-curl#readme",
  "bugs": {
    "url": "https://github.com/sixees/mcp-curl/issues"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsc --watch"
  },
  "keywords": ["mcp", "curl", "http", "model-context-protocol", "claude"],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "typescript": "^5.5.4"
  }
}
